# AI Providers
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# PostgreSQL
DB_HOST=localhost
DB_NAME=jarvis_db
DB_USER=jarvis_user
DB_PASSWORD=your_db_password_here
DB_PORT=5432

# JARVIS settings
WAKE_WORD=jarvis
VOICE_RATE=175
HISTORY_LIMIT=10
PRIMARY_AI=gemini
UI_MODE=both

# Phase 1: Intelligent System Control Layer
RENDER_HEALTH_URL=https://your-app.onrender.com/health
PROACTIVE_MODE=true
GIT_CHECK_INTERVAL_HOURS=2
HOTKEY_ENABLED=true
HOTKEY_COMBO=cmd+shift+space
CORNER_TRIGGER_ENABLED=true
CORNER_TRIGGER_CORNER=top-right
CORNER_TRIGGER_DELAY_MS=1200

# Phase 2: Local LLM + Semantic Memory
LOCAL_LLM_ENABLED=true
LOCAL_LLM_MODEL=phi3:mini
LOCAL_LLM_TIMEOUT=30
OLLAMA_BASE_URL=http://localhost:11434
OFFLINE_FALLBACK_TO_LOCAL=true
AI_PRIORITY=gemini,groq,ollama
SYSTEM_PROMPT_REFRESH_MINUTES=30
